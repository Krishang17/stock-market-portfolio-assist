# Copy to .env for local runs (`npm run briefing`). Never commit the real .env.

# Anthropic API key — https://console.anthropic.com/
# NOTE: the account needs a positive credit balance (Plans & Billing) or every
# read falls back to "Watch / analysis unavailable".
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the Claude model (defaults to claude-sonnet-4-6)
MODEL=claude-sonnet-4-6
